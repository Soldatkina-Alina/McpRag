{
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "Model": "phi3:mini",
    "EmbeddingModel": "nomic-embed-text",
    "TimeoutSeconds": 60,
    "Temperature": 0.7,
    "MaxTokens": 500
  },
  "Indexer": {
    "SupportedExtensions": [".txt", ".md", ".cs", ".js", ".ts", ".json", ".yaml", ".rst"],
    "MaxFileSizeMB": 10,
    "SkipLockedFiles": true
  },
  "VectorStore": {
    "Type": "chromadb",
    "ConnectionString": "http://localhost:8000",
    "CollectionName": "documents",
    "ChunkSize": 500,
    "ChunkOverlap": 200
  },
  "RAG": {
    "MaxChunks": 2,
    "MinRelevanceScore": 0.5,
    "MaxContextTokens": 2000,
    "IncludeMetadataInContext": true,
    "Temperature": 250.0,
    "EnableAnswerGeneration": true,
    "EnableHallucinationCheck": true,
    "EnableRegeneration": true,
    "Retry": {
      "MaxRetries": 2,
      "MinRelevantCount": 1,
      "EnableQueryRewrite": true,
      "ScoreBoostPerRetry": 0.1
    },
    "Hallucination": {
      "Enabled": true,
      "MaxRegenerations": 1,
      "ConfidenceThreshold": 0.5,
      "UseDetailedCheck": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "McpRag": "Information"
    },
    "File": {
      "Path": "logs/app-",
      "FileSizeLimitBytes": 10485760,
      "RetainedFileCountLimit": 30,
      "RollingInterval": "Day"
    }
  }
}