# .gitignore для .NET проекта

# Результаты сборки
bin/
obj/
**/bin/**
**/obj/**

# Настройки Visual Studio
.vs/
**/.vs/**
*.suo
*.user
*.userprefs
*.sln.docstates

# Настройки VS Code
.vscode/*
!.vscode/mcp.json
**/.vscode/*
!**/.vscode/mcp.json
*.code-workspace

# Временные файлы
*.tmp
*.temp
*.log